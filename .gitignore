# OS / temp
.DS_Store
Thumbs.db
*.tmp
~$*
.~lock.*

# Sandbox test artifacts (created during setup; cannot be deleted from this mount)
_cptest/
_deltest.txt

# npm cache written by sandbox (locked — cannot delete from this mount)
.npmcache/

# Node / build artifacts (also covered by app/.gitignore)
node_modules/
dist/
dev-dist/
coverage/

# Cloud Functions compiled output (tsc → lib/). נבנה ב-CI/deploy, לא נשמר ב-git.
functions/lib/

app/vite.config.ts.timestamp-*.mjs

# Firebase deploy cache
.firebase/
