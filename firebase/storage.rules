// firebase/storage.rules — Firebase Storage security rules (חלק 3).
// פרטיות: תמונות אישיות נגישות רק ל-uids מורשים לפרופיל/ילד.
// COPPA/GDPR/חוק הגנת הפרטיות: הפרדה בין פרופילים; אין גישת cross-profile.
// B4: איחוד מודל ההרשאות עם Firestore — הכל דרך childAccess/{id}/members/{uid}
//     (הבעלים נרשם כ-parent ב-childAccess בעת יצירת הילד, ולכן מכוסה גם הוא).

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // בדיקת גישה דרך Firestore: childAccess/{id}/members/{uid} קיים.
    // מכסה גם בעלים (parent) וגם חברים משותפים (clinician/staff).
    function hasChildAccess(id) {
      return request.auth != null
        && firestore.exists(
          /databases/(default)/documents/childAccess/$(id)/members/$(request.auth.uid)
        );
    }

    // ולידציית העלאת מדיה: עד 10MB ותוכן מוצפן (octet-stream).
    function isValidMedia() {
      return request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType == 'application/octet-stream';
    }

    // ========================
    // תמונות אישיות (חלק 3)
    // ========================
    // Path בפועל (services/sync/mediaSync.ts): profiles/{profileId}/media/{mediaId}
    // גישה: רק uid עם childAccess לפרופיל (בעלים או חבר מורשה).
    match /profiles/{profileId}/media/{mediaId} {
      allow read: if hasChildAccess(profileId);
      allow write: if hasChildAccess(profileId) && isValidMedia();
      allow delete: if hasChildAccess(profileId);
    }

    // ==============================
    // תמונות לפי childId (תאימות/עתיד)
    // ==============================
    // Path: children/{childId}/media/{mediaId}
    match /children/{childId}/media/{mediaId} {
      allow read: if hasChildAccess(childId);
      allow write: if hasChildAccess(childId) && isValidMedia();
      allow delete: if hasChildAccess(childId);
    }

    // אסור לכל שאר הנתיבים כברירת מחדל.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
